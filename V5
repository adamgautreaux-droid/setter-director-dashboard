<script>
// ─── NAV ──────────────────────────────────────────────────────
function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  el.classList.add('active');
  if (id === 'morning' && !window.chartsInit) initCharts();
  if (id === 'scorecards' && !window.scoreChartsInit) initScoreCharts();
}

// ─── TRIAGE TABLE ─────────────────────────────────────────────
const reps = [
  { name:'Jose Bernal', brand:'CT', health:'red', flag:'3-day ↓', dials:142, dialT:150, sets:1, setT:5, closes:0, closeT:1, show:'—', ww:'↓ -31%', pri:1 },
  { name:'Caroline Christy', brand:'HPH', health:'red', flag:'3-day ↓', dials:89, dialT:150, sets:3, setT:5, closes:0, closeT:1, show:'32%', ww:'↓ -18%', pri:2 },
  { name:'Samuel Michalcin', brand:'S8T', health:'red', flag:'3-day ↓', dials:108, dialT:150, sets:2, setT:5, closes:1, closeT:1, show:'88%', ww:'↓ -22%', pri:3 },
  { name:'Ben Barrales', brand:'S8T', health:'yellow', flag:'1-day ✗', dials:158, dialT:150, sets:3, setT:5, closes:0, closeT:1, show:'38%', ww:'↓ -8%', pri:4 },
  { name:'Harvey Lemus', brand:'TTW', health:'yellow', flag:'1-day ✗', dials:98, dialT:150, sets:5, setT:5, closes:1, closeT:1, show:'29%', ww:'→ flat', pri:5 },
  { name:'Gloria Sanz', brand:'ECU', health:'green', flag:'On track', dials:162, dialT:150, sets:6, setT:5, closes:1, closeT:1, show:'83%', ww:'↑ +12%', pri:8 },
  { name:'Brent Jackman', brand:'CT', health:'green', flag:'On track', dials:155, dialT:150, sets:6, setT:5, closes:2, closeT:1, show:'75%', ww:'↑ +9%', pri:9 },
  { name:'Saray Cortes', brand:'TTW', health:'green', flag:'On track', dials:154, dialT:150, sets:5, setT:5, closes:0, closeT:1, show:'62%', ww:'↑ +5%', pri:10 },
];

let showAll = false;

function renderTriage() {
  const body = document.getElementById('triage-body');
  const filtered = showAll ? reps : reps.filter(r => r.health !== 'green');
  body.innerHTML = filtered.map(r => {
    const hDot = r.health === 'red' ? 'hr' : r.health === 'yellow' ? 'hy' : 'hg';
    const flagCls = r.health === 'red' ? 'flag-red' : r.health === 'yellow' ? 'flag-amb' : 'flag-ok';
    const rowCls = r.health === 'red' ? 'row-red' : r.health === 'yellow' ? 'row-amber' : 'row-green';
    const priColor = r.health === 'red' ? 'var(--red)' : r.health === 'yellow' ? 'var(--amber)' : 'var(--green)';
    const dOk = r.dials >= r.dialT, sOk = r.sets >= r.setT, cOk = r.closes >= r.closeT;
    const wwCls = r.ww.startsWith('↑') ? 'trend-up' : r.ww.startsWith('↓') ? 'trend-dn' : 'trend-fl';
    return `<tr class="${rowCls}">
      <td style="font-weight:600;color:${priColor}">${r.pri}</td>
      <td style="font-weight:600">${r.name}</td>
      <td><span class="badge bgr">${r.brand}</span></td>
      <td><span class="hdot ${hDot}"></span></td>
      <td><span class="flag ${flagCls}">${r.flag}</span></td>
      <td style="color:${dOk?'var(--teal-mid)':'var(--red)'};font-weight:600">${r.dials}</td>
      <td style="color:var(--text-muted)">${r.dialT}</td>
      <td style="color:${sOk?'var(--teal-mid)':'var(--red)'};font-weight:600">${r.sets}</td>
      <td style="color:var(--text-muted)">${r.setT}</td>
      <td style="color:${cOk?'var(--teal-mid)':'var(--red)'};font-weight:600">${r.closes}</td>
      <td style="color:var(--text-muted)">${r.closeT}</td>
      <td>${r.show}</td>
      <td class="${wwCls}">${r.ww}</td>
    </tr>`;
  }).join('');
}

function toggleAll() {
  showAll = !showAll;
  document.getElementById('toggle-btn').textContent = showAll ? 'Show flagged only' : 'Show all reps';
  renderTriage();
}

renderTriage();

// ─── CHARTS ───────────────────────────────────────────────────
const TEAL = '#1D9E75', RED = '#D93025', AMBER = '#E6A817', PURPLE = '#7F77DD', CORAL = '#D85A30', GRID = 'rgba(0,0,0,0.05)';
window.chartsInit = false;
window.scoreChartsInit = false;

function initCharts() {
  window.chartsInit = true;
  const brands = ['S8T', 'ECU', 'CT', 'TTW', 'HPH', 'DBB'];
  const repCounts = [3, 2, 2, 2, 3, 1];
  const thresholds = repCounts.map(n => n * 25);

  new Chart(document.getElementById('leadFlowYest'), {
    type: 'bar',
    data: {
      labels: brands,
      datasets: [
        { label: 'Rep 1', data: [28, 32, 26, 22, 18, 25], backgroundColor: TEAL + '66', borderColor: TEAL, borderWidth: 1, borderRadius: 3 },
        { label: 'Rep 2', data: [22, 18, 22, 20, 14, 0], backgroundColor: AMBER + '66', borderColor: AMBER, borderWidth: 1, borderRadius: 3 },
        { label: 'Rep 3', data: [15, 0, 0, 0, 10, 0], backgroundColor: PURPLE + '66', borderColor: PURPLE, borderWidth: 1, borderRadius: 3 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: true, labels: { font: { size: 10, family: 'DM Sans' }, boxWidth: 10 } } },
      scales: {
        x: { stacked: true, ticks: { font: { size: 10 } }, grid: { display: false } },
        y: { stacked: true, ticks: { font: { size: 10 } }, grid: { color: GRID } }
      }
    },
    plugins: [{
      id: 'threshLines',
      afterDraw(chart) {
        const { ctx, chartArea: { left, right }, scales: { x, y } } = chart;
        thresholds.forEach((t, i) => {
          const xPos = x.getPixelForValue(i);
          const yPos = y.getPixelForValue(t);
          const bw = x.width / brands.length * 0.55;
          ctx.save();
          ctx.strokeStyle = RED;
          ctx.lineWidth = 2;
          ctx.setLineDash([5, 3]);
          ctx.beginPath();
          ctx.moveTo(xPos - bw / 2, yPos);
          ctx.lineTo(xPos + bw / 2, yPos);
          ctx.stroke();
          ctx.restore();
        });
      }
    }]
  });
}

function initScoreCharts() {
  window.scoreChartsInit = true;
  const brands = ['S8T', 'ECU', 'CT', 'TTW', 'HPH', 'DBB'];
  const repCounts = [3, 2, 2, 2, 3, 1];
  const mtdThresh = repCounts.map(n => n * 25 * 9);

  new Chart(document.getElementById('leadFlowMTD'), {
    type: 'bar',
    data: {
      labels: brands,
      datasets: [
        { label: 'Rep 1', data: [252, 288, 234, 198, 162, 225], backgroundColor: TEAL + '66', borderColor: TEAL, borderWidth: 1, borderRadius: 3 },
        { label: 'Rep 2', data: [198, 162, 198, 180, 126, 0], backgroundColor: AMBER + '66', borderColor: AMBER, borderWidth: 1, borderRadius: 3 },
        { label: 'Rep 3', data: [135, 0, 0, 0, 90, 0], backgroundColor: PURPLE + '66', borderColor: PURPLE, borderWidth: 1, borderRadius: 3 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: true, labels: { font: { size: 10, family: 'DM Sans' }, boxWidth: 10 } } },
      scales: {
        x: { stacked: true, ticks: { font: { size: 10 } }, grid: { display: false } },
        y: { stacked: true, ticks: { font: { size: 10 } }, grid: { color: GRID } }
      }
    },
    plugins: [{
      id: 'mtdThreshLines',
      afterDraw(chart) {
        const { ctx, scales: { x, y } } = chart;
        mtdThresh.forEach((t, i) => {
          const xPos = x.getPixelForValue(i);
          const yPos = y.getPixelForValue(t);
          const bw = x.width / brands.length * 0.55;
          ctx.save();
          ctx.strokeStyle = RED;
          ctx.lineWidth = 2;
          ctx.setLineDash([5, 3]);
          ctx.beginPath();
          ctx.moveTo(xPos - bw / 2, yPos);
          ctx.lineTo(xPos + bw / 2, yPos);
          ctx.stroke();
          ctx.restore();
        });
      }
    }]
  });
}

// init morning chart on load
window.addEventListener('load', initCharts);
</script>
