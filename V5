<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WFS Setter Director Dashboard — V5</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

:root {
  --teal: #0F6E56;
  --teal-mid: #1D9E75;
  --teal-light: #E1F5EE;
  --teal-border: #9FE1CB;
  --amber: #BA7517;
  --amber-light: #FEF7E0;
  --amber-border: #FAC775;
  --red: #C5221F;
  --red-light: #FCE8E6;
  --red-border: #F5C6C2;
  --green: #137333;
  --green-light: #E6F4EA;
  --green-border: #A8D5B5;
  --blue: #1967D2;
  --blue-light: #E8F0FE;
  --bg: #F5F5F3;
  --surface: #FFFFFF;
  --surface2: #F8F8F6;
  --border: #E8E6E0;
  --border-strong: #D0CEC8;
  --text: #1A1A18;
  --text-muted: #6B6860;
  --text-hint: #9A9890;
  --chrome: #1A2332;
  --chrome-text: #8A9BB0;
  --font: 'DM Sans', sans-serif;
  --mono: 'DM Mono', monospace;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 13px; line-height: 1.5; }

/* ─── CHROME ─────────────────────── */
.chrome { background: var(--chrome); padding: 0 20px; display: flex; align-items: center; gap: 0; height: 48px; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 0 rgba(255,255,255,.06); }
.chrome-brand { display: flex; align-items: center; gap: 10px; margin-right: 32px; }
.chrome-logo { width: 28px; height: 28px; background: var(--teal); border-radius: 6px; display: flex; align-items: center; justify-content: center; }
.chrome-logo svg { width: 16px; height: 16px; fill: #fff; }
.chrome-title { font-size: 13px; font-weight: 500; color: #E8EDF2; letter-spacing: -.01em; }
.chrome-badge { font-size: 10px; padding: 1px 7px; border-radius: 10px; background: rgba(255,255,255,.1); color: var(--chrome-text); font-weight: 500; margin-left: 4px; }
.nav-tabs { display: flex; gap: 0; height: 48px; }
.nav-tab { padding: 0 16px; font-size: 12px; font-weight: 500; color: var(--chrome-text); cursor: pointer; display: flex; align-items: center; border-bottom: 2px solid transparent; transition: all .15s; white-space: nowrap; }
.nav-tab:hover { color: #C8D4E0; }
.nav-tab.active { color: #E8EDF2; border-bottom-color: var(--teal-mid); }
.chrome-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
.sync-badge { font-size: 10px; color: var(--chrome-text); display: flex; align-items: center; gap: 5px; }
.sync-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal-mid); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

/* ─── FILTERS BAR ────────────────── */
.filter-bar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 8px 20px; display: flex; gap: 8px; align-items: center; }
.filter-ctl { display: flex; align-items: center; gap: 5px; padding: 5px 10px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); font-size: 11px; color: var(--text-muted); cursor: pointer; transition: border-color .15s; font-family: var(--font); }
.filter-ctl:hover { border-color: var(--border-strong); }
.filter-ctl.date-ctl { background: var(--teal-light); border-color: var(--teal-border); color: var(--teal); font-weight: 500; }
.filter-ctl svg { width: 12px; height: 12px; opacity: .6; }
.filter-arrow { font-size: 8px; opacity: .5; }
.filter-sep { width: 1px; height: 16px; background: var(--border); margin: 0 4px; }

/* ─── BODY ───────────────────────── */
.body { padding: 16px 20px 40px; }
.page { display: none; }
.page.active { display: block; }

/* ─── SECTION HEADER ─────────────── */
.section-hdr { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--text-hint); margin: 16px 0 8px; padding-bottom: 6px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.section-hdr-label { display: flex; align-items: center; gap: 6px; }

/* ─── SCORECARD GRID ─────────────── */
.sc-grid { display: grid; gap: 8px; margin-bottom: 12px; }
.sc-6 { grid-template-columns: repeat(6, minmax(0,1fr)); }
.sc-4 { grid-template-columns: repeat(4, minmax(0,1fr)); }
.sc { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; }
.sc-label { font-size: 10px; color: var(--text-hint); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
.sc-value { font-size: 22px; font-weight: 500; line-height: 1.1; margin-bottom: 3px; }
.sc-pace { font-size: 10px; color: var(--text-muted); }
.sc-proj { font-size: 10px; margin-top: 1px; }
.c-up { color: var(--teal-mid); }
.c-dn { color: var(--red); }
.c-warn { color: var(--amber); }
.c-muted { color: var(--text-muted); }

/* ─── TWO / THREE COL ────────────── */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
.three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px; }

/* ─── CARD ───────────────────────── */
.card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 14px; margin-bottom: 10px; }
.card-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text-hint); margin-bottom: 10px; }

/* ─── TABLE ──────────────────────── */
.tbl-wrap { overflow-x: auto; margin-bottom: 10px; }
.tbl { width: 100%; border-collapse: collapse; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; font-size: 11px; }
.tbl th { text-align: left; padding: 7px 10px; font-size: 9px; font-weight: 600; color: var(--text-hint); background: var(--surface2); border-bottom: 1px solid var(--border); white-space: nowrap; text-transform: uppercase; letter-spacing: .04em; }
.tbl td { padding: 7px 10px; border-bottom: 1px solid #F2F0EA; color: var(--text); white-space: nowrap; }
.tbl tr:last-child td { border-bottom: none; }
.tbl tr:hover td { background: #FAFAF8; }
.tbl .tot td { font-weight: 600; background: var(--surface2); }
.tbl .row-red td { background: #FFF8F7; }
.tbl .row-amber td { background: #FFFDF4; }
.tbl .row-green td { background: #F7FDF9; }
.th-grp { background: var(--teal-light) !important; color: var(--teal) !important; text-align: center !important; font-size: 8px !important; }

/* ─── BADGES ─────────────────────── */
.badge { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 9px; font-weight: 600; }
.bg { background: var(--green-light); color: var(--green); }
.by { background: var(--amber-light); color: var(--amber); }
.br { background: var(--red-light); color: var(--red); }
.bb { background: var(--blue-light); color: var(--blue); }
.bgr { background: var(--surface2); color: var(--text-muted); }
.bteal { background: var(--teal-light); color: var(--teal); }

/* ─── HEALTH DOT ─────────────────── */
.hdot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.hg { background: #1D9E75; }
.hy { background: #E6A817; }
.hr { background: #D93025; }

/* ─── FLAGS ──────────────────────── */
.flag { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 9px; font-weight: 600; }
.flag-red { background: var(--red-light); color: var(--red); }
.flag-amb { background: var(--amber-light); color: var(--amber); }
.flag-ok { background: var(--green-light); color: var(--green); }

/* ─── TREND ──────────────────────── */
.trend-up { color: #1D9E75; font-size: 10px; font-weight: 600; }
.trend-dn { color: #D93025; font-size: 10px; font-weight: 600; }
.trend-fl { color: var(--text-muted); font-size: 10px; }

/* ─── TRIAGE TABLE ───────────────── */
.triage-controls { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.toggle-btn { font-size: 11px; padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--surface); color: var(--teal); cursor: pointer; font-weight: 500; font-family: var(--font); transition: all .15s; }
.toggle-btn:hover { background: var(--teal-light); border-color: var(--teal-border); }
.count-pills { display: flex; gap: 6px; }

/* ─── ALERT ROWS ─────────────────── */
.alert-row { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; border-radius: 6px; margin-bottom: 6px; border: 1px solid; }
.ar-r { background: var(--red-light); border-color: var(--red-border); }
.ar-y { background: var(--amber-light); border-color: var(--amber-border); }
.ar-g { background: var(--green-light); border-color: var(--green-border); }
.ar-icon { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
.ai-r { background: #EA4335; color: #fff; }
.ai-y { background: #FBBC04; color: #202124; }
.ai-g { background: #34A853; color: #fff; }
.ar-body { flex: 1; }
.ar-title { font-size: 11px; font-weight: 600; margin-bottom: 2px; }
.ar-r .ar-title { color: var(--red); }
.ar-y .ar-title { color: var(--amber); }
.ar-g .ar-title { color: var(--green); }
.ar-detail { font-size: 10px; color: var(--text-muted); line-height: 1.5; }
.ar-meta { font-size: 9px; margin-top: 3px; opacity: .6; font-family: var(--mono); }

/* ─── RED ZONE BADGES ────────────── */
.rz-hot { background: var(--red-light); color: var(--red); padding: 2px 7px; border-radius: 4px; font-size: 9px; font-weight: 600; display: inline-block; }
.rz-warm { background: var(--amber-light); color: var(--amber); padding: 2px 7px; border-radius: 4px; font-size: 9px; font-weight: 600; display: inline-block; }
.rz-ok { background: var(--green-light); color: var(--green); padding: 2px 7px; border-radius: 4px; font-size: 9px; font-weight: 600; display: inline-block; }

/* ─── FUNNEL ─────────────────────── */
.funnel-row { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
.funnel-lbl { font-size: 9px; color: var(--text-muted); width: 90px; text-align: right; flex-shrink: 0; }
.funnel-bg { flex: 1; background: #F0EEE8; border-radius: 3px; height: 18px; }
.funnel-fill { height: 18px; border-radius: 3px; display: flex; align-items: center; padding-left: 7px; }
.funnel-val { font-size: 10px; font-weight: 600; color: #fff; font-family: var(--mono); }

/* ─── BENCH ──────────────────────── */
.bench-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid var(--border); font-size: 11px; }
.bench-row:last-child { border-bottom: none; }

/* ─── PIVOT ──────────────────────── */
.pivot { width: 100%; border-collapse: collapse; font-size: 10px; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.pivot th { padding: 6px 10px; font-size: 9px; font-weight: 600; color: var(--text-hint); background: var(--surface2); border: 1px solid var(--border); text-align: center; text-transform: uppercase; letter-spacing: .04em; }
.pivot td { padding: 6px 10px; border: 1px solid #F2F0EA; text-align: center; }
.pivot .setter-col { text-align: left; font-weight: 600; background: var(--surface2); }
.pivot .closer-avg { font-weight: 600; background: var(--surface2); }

/* ─── NOTE BOX ───────────────────── */
.note-box { background: var(--teal-light); border: 1px solid var(--teal-border); border-radius: 6px; padding: 10px 14px; font-size: 11px; color: var(--teal); margin-bottom: 10px; line-height: 1.6; }

/* ─── PAGE HEADER ────────────────── */
.page-meta { display: flex; gap: 16px; margin-bottom: 14px; }
.page-meta-item { font-size: 11px; color: var(--text-muted); }
.page-meta-item strong { color: var(--text); font-weight: 600; }

/* scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 10px; }

/* responsive */
@media (max-width: 900px) {
  .sc-6 { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .sc-4 { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .two-col, .three-col { grid-template-columns: 1fr; }
  .rep-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
}
</style>
</head>
